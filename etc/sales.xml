    </section>
    <section name="order_creditmemo">
        <group name="totals">
            <item name="panth_extra_fee" instance="Panth\ExtraFee\Model\Total\Creditmemo\ExtraFee" sort_order="450"/>
        </group>
    </section>
</config>
